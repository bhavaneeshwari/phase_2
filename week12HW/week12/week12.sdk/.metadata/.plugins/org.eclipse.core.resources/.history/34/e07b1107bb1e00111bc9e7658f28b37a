#include <string.h>
#include "xil_printf.h"
#include "axi_regs.h"
#include "parser.h"
#include "func_desc.h"

void parse_and_store(char *input)
{
    if (READ_CMD() != 0) {
        xil_printf("[PARSER] HW busy\r\n");
        return;
    }

    for (int i = 0; i < 32; i++) HW_OPERAND_BASE[i] = 0x00;

    /* STEP 1 — extract cmd name */
    char *cmd = strtok(input, "(");
    if (!cmd) return;

    /* STEP 2 — lookup descriptor by name */
    const func_desc_t *desc = lookup_by_name(cmd);
    if (!desc) {
        xil_printf("[PARSER] unknown cmd: %s\r\n", cmd);
        WRITE_OPCODE(OPCODE_INVALID);
        WRITE_STATUS(TI_AFE_RET_EXEC_FAIL);
        WRITE_CMD(0);
        return;
    }

    /* STEP 3 — write opcode via enum */
    WRITE_OPCODE(desc->opcode);
    xil_printf("[PARSER] cmd=%s opcode=0x%02X\r\n",
               desc->cmd_name, desc->opcode);

    /* STEP 4 — parse args */
    char *arg_string = strtok(NULL, ")");
    if (!arg_string) return;

    arg_list_t args = {0};
    parse_args(arg_string, &args);

    /* STEP 5 — validate min arg count using descriptor */
    if (args.count < desc->min_args) {
        xil_printf("[PARSER] too few args: got %d expected %d\r\n",
                   args.count, desc->min_args);
        WRITE_STATUS(TI_AFE_RET_EXEC_FAIL);
        WRITE_CMD(0);
        return;
    }

    /* STEP 6 — log arg types from descriptor */
    for (int i = 0; i < desc->min_args; i++) {
        xil_printf("[PARSER] arg[%d] type=%d val=0x%08X\r\n",
                   i, desc->arg_types[i], args.val[i]);
    }

    /* STEP 7 — dispatch via function pointer */
    desc->handler(&args);

    /* STEP 8 — signal HW */
    WRITE_CMD(1);
    xil_printf("[PARSER] done\r\n");
}
