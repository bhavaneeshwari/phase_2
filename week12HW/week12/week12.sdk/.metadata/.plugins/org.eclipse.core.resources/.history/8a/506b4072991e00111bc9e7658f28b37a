#include "xparameters.h"
#include "xil_types.h"
#include "xil_io.h"
#include "xuartlite.h"
#include <string.h>

#define REG_BASE_ADDR   XPAR_REG_32IP_0_SREG_AXI_BASEADDR
#define OPERAND_PTR     ((volatile u8 *)(REG_BASE_ADDR + 0x00))
#define RESULT_PTR      ((volatile u8 *)(REG_BASE_ADDR + 0x24))

XUartLite Uart;
extern char inbyte(void);

void uart_init(void) {
    XUartLite_Initialize(&Uart, XPAR_UARTLITE_0_DEVICE_ID);
}

int main() {
    uart_init();

    // --- Write operands ---
    u8  sel  = 0x01;        // operation selector
    u32 addr = 0x00000004;  // target address
    u32 data = 0xDEADBEEF; // data to write

    u32 offset = 0;
    memcpy((void *)(OPERAND_PTR + offset), &sel,  sizeof(sel));  offset += sizeof(sel);
    memcpy((void *)(OPERAND_PTR + offset), &addr, sizeof(addr)); offset += sizeof(addr);
    memcpy((void *)(OPERAND_PTR + offset), &data, sizeof(data)); offset += sizeof(data);

    xil_printf("=== Operands Written ===\r\n");
    xil_printf("  sel  = 0x%02X\r\n", sel);
    xil_printf("  addr = 0x%08X\r\n", addr);
    xil_printf("  data = 0x%08X\r\n", data);

    // --- Read back result (9 bytes: 1 + 4 + 4) ---
    u8  r_sel  = 0;
    u32 r_addr = 0;
    u32 r_data = 0;

    offset = 0;
    memcpy(&r_sel,  (void *)(RESULT_PTR + offset), sizeof(r_sel));  offset += sizeof(r_sel);
    memcpy(&r_addr, (void *)(RESULT_PTR + offset), sizeof(r_addr)); offset += sizeof(r_addr);
    memcpy(&r_data, (void *)(RESULT_PTR + offset), sizeof(r_data)); offset += sizeof(r_data);

    xil_printf("\r\n=== Result Read Back ===\r\n");
    xil_printf("  sel  = 0x%02X\r\n", r_sel);
    xil_printf("  addr = 0x%08X\r\n", r_addr);
    xil_printf("  data = 0x%08X\r\n", r_data);

    return 0;
}
